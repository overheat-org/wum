{
	"compilerOptions": {
		"noEmit": true,
		"module": "esnext",
		"lib": ["ESNext", "DOM"],
		"target": "esnext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"noImplicitAny": false,
		"allowImportingTsExtensions": true,
		"sourceMap": true
	},
	"include": [
		"./src/index.ts",
		"./src/plugin.ts",
		"./src/adapter.ts",
		"./src/config.ts",
		"./src/scanner.ts"
	]
}
